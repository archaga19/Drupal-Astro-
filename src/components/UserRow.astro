---
import type { DrupalUser } from "../types/DrupalUser";

interface Props {
  user: DrupalUser;
}

const { user } = Astro.props;
---

<tr>
  <td>{user.uid}</td>
  <td class="username">{user.name || "Anónimo"}</td>
  <td>{user.mail || "—"}</td>
  <td>
    {
      user.field_organizacion ? (
        <span class="org-text">{user.field_organizacion}</span>
      ) : (
        <span class="none-text">N/A</span>
      )
    }
  </td>
  <td>
    <span class="role-text">{user.roles_target_id || "sin rol"}</span>
  </td>
</tr>

<style>
  tr {
    border-bottom: 1px solid #e2e8f0;
    transition: background 0.15s;
  }
  tr:hover {
    background: #f8fafc;
  }
  td {
    padding: 12px 15px;
    color: #334155;
    vertical-align: middle;
  }
  .username {
    font-weight: 500;
    color: #0f172a;
  }
  .role-text {
    color: #475569;
    font-size: 0.85rem;
  }
  .org-text {
    color: #1e40af;
    font-weight: 500;
    font-size: 0.85rem;
  }
  .none-text {
    color: #94a3b8;
    font-style: italic;
  }
</style>
